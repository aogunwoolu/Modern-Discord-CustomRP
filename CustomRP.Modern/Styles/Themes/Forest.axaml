<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Forest — dark canopy greens with emerald accent -->
    <Color x:Key="AppBackgroundColor">#08100C</Color>
    <Color x:Key="AppSurfaceColor">#0E1A14</Color>
    <Color x:Key="AppSurfaceElevatedColor">#12201A</Color>
    <Color x:Key="AppSurfaceHoverColor">#182C22</Color>
    <Color x:Key="AppBorderColor">#1E3828</Color>
    <Color x:Key="AppTextPrimaryColor">#E0F5E8</Color>
    <Color x:Key="AppTextSecondaryColor">#7AB58E</Color>
    <Color x:Key="AppTextMutedColor">#476E56</Color>
    <Color x:Key="AppAccentColor">#00C853</Color>
    <Color x:Key="AppAccentHoverColor">#00E676</Color>
    <Color x:Key="AppAccentPressedColor">#009624</Color>
    <Color x:Key="AppSuccessColor">#81C784</Color>
    <Color x:Key="AppWarningColor">#FFD54F</Color>
    <Color x:Key="AppDangerColor">#EF5350</Color>
    <Color x:Key="AppDiscordCardColor">#0F1E18</Color>
    <Color x:Key="AppDiscordCardHeaderColor">#08110C</Color>

</ResourceDictionary>
