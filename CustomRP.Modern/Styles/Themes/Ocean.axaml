<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Ocean — deep sea blues with teal/cyan accent -->
    <Color x:Key="AppBackgroundColor">#060D14</Color>
    <Color x:Key="AppSurfaceColor">#0B1825</Color>
    <Color x:Key="AppSurfaceElevatedColor">#0F1F30</Color>
    <Color x:Key="AppSurfaceHoverColor">#152840</Color>
    <Color x:Key="AppBorderColor">#1C3A55</Color>
    <Color x:Key="AppTextPrimaryColor">#D8EEFF</Color>
    <Color x:Key="AppTextSecondaryColor">#6FA3C4</Color>
    <Color x:Key="AppTextMutedColor">#3E6E8A</Color>
    <Color x:Key="AppAccentColor">#00BCD4</Color>
    <Color x:Key="AppAccentHoverColor">#26C6DA</Color>
    <Color x:Key="AppAccentPressedColor">#0097A7</Color>
    <Color x:Key="AppSuccessColor">#00E676</Color>
    <Color x:Key="AppWarningColor">#FFD740</Color>
    <Color x:Key="AppDangerColor">#FF5252</Color>
    <Color x:Key="AppDiscordCardColor">#0D1E2E</Color>
    <Color x:Key="AppDiscordCardHeaderColor">#071018</Color>

</ResourceDictionary>
