<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Nord — arctic palette inspired by the Nord color scheme -->
    <Color x:Key="AppBackgroundColor">#2E3440</Color>
    <Color x:Key="AppSurfaceColor">#3B4252</Color>
    <Color x:Key="AppSurfaceElevatedColor">#434C5E</Color>
    <Color x:Key="AppSurfaceHoverColor">#4C566A</Color>
    <Color x:Key="AppBorderColor">#5A6480</Color>
    <Color x:Key="AppTextPrimaryColor">#ECEFF4</Color>
    <Color x:Key="AppTextSecondaryColor">#D8DEE9</Color>
    <Color x:Key="AppTextMutedColor">#9099A6</Color>
    <Color x:Key="AppAccentColor">#5E81AC</Color>
    <Color x:Key="AppAccentHoverColor">#81A1C1</Color>
    <Color x:Key="AppAccentPressedColor">#4C6F8C</Color>
    <Color x:Key="AppSuccessColor">#A3BE8C</Color>
    <Color x:Key="AppWarningColor">#EBCB8B</Color>
    <Color x:Key="AppDangerColor">#BF616A</Color>
    <Color x:Key="AppDiscordCardColor">#3B4252</Color>
    <Color x:Key="AppDiscordCardHeaderColor">#2E3440</Color>

</ResourceDictionary>
